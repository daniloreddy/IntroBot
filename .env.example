# ============================================================
# IntroBot – variabili d'ambiente
# Copia questo file in .env e compila i valori
# ============================================================

# [OBBLIGATORIO] Token del bot Discord
# Ottenibile da https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# [Opzionale] ID Discord dell'owner/fallback admin
# Default: 123456789012345678
DISCORD_FALLBACK_ID=

# [Opzionale] Livello di log: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# [Opzionale] Percorso al binario ffmpeg
# Necessario solo se ffmpeg non è nel PATH di sistema.
# ffprobe viene cercato nella stessa directory di ffmpeg automaticamente.
# Esempio Windows: FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# Esempio Linux:   FFMPEG_PATH=/usr/local/bin/ffmpeg
FFMPEG_PATH=

# [Opzionale] Percorso al binario ffprobe
# Impostare solo se ffprobe si trova in una directory diversa da ffmpeg.
FFPROBE_PATH=
